<IfModule mod_rewrite.c>
    # Block access to hidden files (.env, .git, etc.)
    RewriteRule ^\. - [F,L]
    
    # Block access to internal Laravel directories
    RewriteRule ^(app|bootstrap|config|database|resources|routes|storage|tests|vendor)(/|$) - [F,L]

    # Disable directory indexing and force fallback to index.php
    # Options -Indexes
    DirectoryIndex index.php

    RewriteEngine On

    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^ index.php [L]
</IfModule>
